# ---- Server ----
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed origins, or * for any (dev only)
ORIGIN=http://localhost:3000

# ---- Database (PostgreSQL) ----
# Local docker-compose default:
DATABASE_URL=postgresql://connect:connect@localhost:5432/connect?schema=public

# ---- Redis ----
# Used for presence, viewer counts and the Socket.IO adapter (horizontal scale-out).
# Leave empty to run a single instance with an in-memory fallback (dev only).
REDIS_URL=redis://localhost:6379

# ---- Firebase Admin (server-side ID token verification) ----
# Provide the service-account JSON as a single-line string, OR a path to the file.
# If neither is set, the server runs in DEV AUTH FALLBACK mode (decodes tokens
# WITHOUT verification and logs a warning). Never deploy to production like that.
FIREBASE_PROJECT_ID=edustax-connect
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json
